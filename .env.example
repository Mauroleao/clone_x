# ============================================
# Django Settings
# ============================================
DEBUG=True
SECRET_KEY=django-insecure-sua-chave-super-secreta-aqui-mude-em-producao
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,seu-dominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://seu-frontend.vercel.app

# ============================================
# Database
# ============================================
# SQLite (default para desenvolvimento):
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (para produção):
# DATABASE_URL=postgresql://user:password@localhost:5432/clone_x

# ============================================
# Email
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:8000

# ============================================
# Gunicorn
# ============================================
GUNICORN_WORKERS=4
